	cd /home/jwauters/.local/share/plasma/plasmoids/org.kde.plasma.vibra/build/vibra_build && $(MAKE) $(MAKESILENT) -f tests/CMakeFiles/vibra_unit_tests.dir/build.make tests/CMakeFiles/vibra_unit_tests.dir/utils/ring_buffer_test.cpp.i
.PHONY : utils/ring_buffer_test.cpp.i

utils/ring_buffer_test.s: utils/ring_buffer_test.cpp.s
.PHONY : utils/ring_buffer_test.s

# target to generate assembly for a file
utils/ring_buffer_test.cpp.s:
