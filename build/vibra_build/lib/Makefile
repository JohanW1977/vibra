	cd /home/jwauters/.local/share/plasma/plasmoids/org.kde.plasma.vibra/build/vibra_build && $(MAKE) $(MAKESILENT) -f lib/CMakeFiles/vibra_static.dir/build.make lib/CMakeFiles/vibra_static.dir/audio/wav.cpp.i
